#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

ynh_setup_source --dest_dir="$install_dir" --keep=".env"

#=================================================
# REAPPLY CONFIGURATION
#=================================================
ynh_script_progression "Refreshing writable paths and system configuration..."

mkdir -p "$data_dir"
fix_app_permissions
ynh_config_add --template=".env" --destination="$install_dir/.env"
ynh_config_add_nginx

#=================================================
# REBUILD APPLICATION
#=================================================
ynh_script_progression "Reinstalling dependencies, syncing MySQL schema, and rebuilding $app..."

pushd "$install_dir"
ynh_hide_warnings ynh_exec_as_app npm install
ynh_hide_warnings ynh_exec_as_app npm run build
ynh_hide_warnings ynh_exec_as_app npm run db:generate
ynh_hide_warnings ynh_exec_as_app npm run db:deploy
popd

fix_app_permissions

#=================================================
# RESTART SERVICE
#=================================================
ynh_script_progression "Restarting $app's service..."

ynh_config_add_systemd
ynh_systemctl --service="$app" --action=restart

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
